<Window x:Class="WindowSpot.AddFavoriteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="즐겨찾기 추가"
        Width="420"
        Height="480"
        WindowStartupLocation="CenterScreen"
        Background="#F0202020"
        ResizeMode="NoResize"
        PreviewKeyDown="Window_PreviewKeyDown">
    <DockPanel Margin="16">
        <TextBox x:Name="FilterBox"
                 DockPanel.Dock="Top"
                 Background="#1AFFFFFF"
                 BorderThickness="0"
                 Foreground="White"
                 CaretBrush="White"
                 FontSize="15"
                 Padding="10,8"
                 Margin="0,0,0,10"
                 TextChanged="FilterBox_TextChanged"/>
        <ListBox x:Name="RowsList"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="White"
                 MouseDoubleClick="RowsList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="6,6">
                        <TextBlock Text="{Binding Display}" Foreground="White" FontSize="14"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
