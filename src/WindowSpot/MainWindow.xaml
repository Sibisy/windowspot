<Window x:Class="WindowSpot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowSpot"
        Width="640"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Visibility="Hidden"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <ContentPresenter/>
        </ControlTemplate>
        <DataTemplate x:Key="IconButtonTemplate">
            <Button Click="IconButton_Click" Template="{StaticResource FlatButtonTemplate}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand" Width="56" Margin="0,0,16,0">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="40" Height="40">
                        <Image Source="{Binding Icon}" Visibility="{Binding IconVisibility}" Width="40" Height="40"/>
                        <Border Visibility="{Binding FallbackVisibility}" Background="#1FFFFFFF" CornerRadius="20">
                            <TextBlock Text="{Binding FallbackLetter}" Foreground="#CCFFFFFF" FontSize="16" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding Label}" Foreground="#B3FFFFFF" FontSize="11" HorizontalAlignment="Center"
                               Margin="0,4,0,0" MaxWidth="56" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="즐겨찾기 제거" Click="RemoveFavorite_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </DataTemplate>
        <DataTemplate x:Key="PlainIconButtonTemplate">
            <Button Click="IconButton_Click" Template="{StaticResource FlatButtonTemplate}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand" Width="56" Margin="0,0,16,0">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="40" Height="40">
                        <Image Source="{Binding Icon}" Visibility="{Binding IconVisibility}" Width="40" Height="40"/>
                        <Border Visibility="{Binding FallbackVisibility}" Background="#1FFFFFFF" CornerRadius="20">
                            <TextBlock Text="{Binding FallbackLetter}" Foreground="#CCFFFFFF" FontSize="16" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding Label}" Foreground="#B3FFFFFF" FontSize="11" HorizontalAlignment="Center"
                               Margin="0,4,0,0" MaxWidth="56" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Button>
        </DataTemplate>
    </Window.Resources>
    <Border Background="#F0202020" CornerRadius="12" BorderBrush="#33FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Grid>
            <!-- 검색 모드 -->
            <StackPanel x:Name="SearchModePanel">
                <Grid Margin="18,16,18,16">
                    <TextBlock x:Name="GhostTextBlock" Foreground="#55FFFFFF" FontSize="26" IsHitTestVisible="False"/>
                    <TextBox x:Name="QueryBox"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             CaretBrush="White"
                             FontSize="26"
                             Padding="0"
                             TextChanged="QueryBox_TextChanged"/>
                </Grid>
                <Border Height="1" Background="#22FFFFFF"/>

                <StackPanel x:Name="FavoritesSection" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="16,12,16,12">
                        <ItemsControl x:Name="FavoritesList" ItemTemplate="{StaticResource IconButtonTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <Button x:Name="AddFavoriteButton" Click="AddFavoriteButton_Click"
                                Template="{StaticResource FlatButtonTemplate}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Width="56">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="40" Height="40" Background="#14FFFFFF" CornerRadius="20">
                                    <TextBlock Text="+" Foreground="#B3FFFFFF" FontSize="20"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="추가" Foreground="#B3FFFFFF" FontSize="11"
                                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel x:Name="TopAppsSection" Visibility="Collapsed">
                        <Border Height="1" Background="#1AFFFFFF"/>
                        <StackPanel Margin="16,10,16,10">
                            <TextBlock Text="자주 쓰는 앱" Foreground="#73FFFFFF" FontSize="11" Margin="0,0,0,10"/>
                            <ItemsControl x:Name="TopAppsList" ItemTemplate="{StaticResource PlainIconButtonTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                    <Border Height="1" Background="#22FFFFFF"/>
                </StackPanel>

                <ListBox x:Name="ResultsList"
                         Background="Transparent"
                         BorderThickness="0"
                         MaxHeight="400"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Focusable="False"
                         PreviewMouseLeftButtonUp="ResultsList_PreviewMouseLeftButtonUp">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="14,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Source="{Binding Icon}" Width="32" Height="32" Margin="0,0,12,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontSize="15"/>
                                    <TextBlock Text="{Binding Subtitle}" Foreground="#99FFFFFF" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6" Margin="6,2">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#405A9EFF"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#15FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Border x:Name="AskAiSection" Visibility="Collapsed" BorderThickness="0">
                    <StackPanel>
                        <Border Height="1" Background="#1AFFFFFF"/>
                        <Button x:Name="AskAiButton" Click="AskAiButton_Click"
                                Template="{StaticResource FlatButtonTemplate}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Margin="16,12,16,12">
                                <Border Width="32" Height="32" Background="#14FFFFFF" CornerRadius="16" Margin="0,0,12,0">
                                    <TextBlock Text="&#10024;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="AskAiLabel" Text="Ask AI" Foreground="White" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- AI 채팅 모드 -->
            <Grid x:Name="ChatModePanel" Visibility="Collapsed" Height="520">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="16,12,16,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="28" Height="28" Background="#1AFFFFFF" CornerRadius="14"
                            Cursor="Hand" MouseLeftButtonUp="BackFromChat_Click">
                        <TextBlock Text="&#8592;" Foreground="White" FontSize="15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="AI Chat" Foreground="White" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                </Grid>
                <Border Grid.Row="1" Height="1" Background="#1AFFFFFF"/>

                <ScrollViewer Grid.Row="2" x:Name="ChatScroll" Margin="16,8,16,8">
                    <ItemsControl x:Name="ChatMessagesList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border HorizontalAlignment="{Binding Alignment}"
                                        Background="{Binding BubbleBrush}"
                                        CornerRadius="14"
                                        Margin="0,4"
                                        MaxWidth="420"
                                        Padding="12,8">
                                    <TextBlock Text="{Binding Text}" Foreground="White" TextWrapping="Wrap" FontSize="13"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="3" Height="1" Background="#1AFFFFFF"/>

                <Grid Grid.Row="4" Margin="12,8,12,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ChatInputBox" Grid.Column="0"
                             Background="Transparent" BorderThickness="0" Foreground="White" CaretBrush="White"
                             FontSize="14" Padding="8" TextWrapping="Wrap"
                             PreviewKeyDown="ChatInputBox_PreviewKeyDown"/>
                    <Border Grid.Column="1" Width="34" Height="34" Background="#5A9EFF" CornerRadius="17"
                            Cursor="Hand" MouseLeftButtonUp="SendChat_Click">
                        <TextBlock Text="&#8593;" Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
