<Window x:Class="WindowSpot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WindowSpot"
        Width="680"
        FontFamily="Segoe UI Variable Display, Segoe UI, Segoe UI Emoji"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        Visibility="Hidden"
        Deactivated="Window_Deactivated"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <ControlTemplate x:Key="FlatButtonTemplate" TargetType="Button">
            <ContentPresenter/>
        </ControlTemplate>
        <DataTemplate x:Key="IconButtonTemplate">
            <Button Click="IconButton_Click" Template="{StaticResource FlatButtonTemplate}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand" Width="60" Margin="0,0,18,0">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="44" Height="44">
                        <Image Source="{Binding Icon}" Visibility="{Binding IconVisibility}" Width="44" Height="44"/>
                        <Border Visibility="{Binding FallbackVisibility}" Background="#1FFFFFFF" CornerRadius="12">
                            <TextBlock Text="{Binding FallbackLetter}" Foreground="#CCFFFFFF" FontSize="17" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding Label}" Foreground="#AEFFFFFF" FontSize="11" HorizontalAlignment="Center"
                               Margin="0,6,0,0" MaxWidth="60" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="즐겨찾기 제거" Click="RemoveFavorite_Click"/>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </DataTemplate>
        <DataTemplate x:Key="PlainIconButtonTemplate">
            <Button Click="IconButton_Click" Template="{StaticResource FlatButtonTemplate}"
                    Background="Transparent" BorderThickness="0" Cursor="Hand" Width="60" Margin="0,0,18,0">
                <StackPanel HorizontalAlignment="Center">
                    <Grid Width="44" Height="44">
                        <Image Source="{Binding Icon}" Visibility="{Binding IconVisibility}" Width="44" Height="44"/>
                        <Border Visibility="{Binding FallbackVisibility}" Background="#1FFFFFFF" CornerRadius="12">
                            <TextBlock Text="{Binding FallbackLetter}" Foreground="#CCFFFFFF" FontSize="17" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{Binding Label}" Foreground="#AEFFFFFF" FontSize="11" HorizontalAlignment="Center"
                               Margin="0,6,0,0" MaxWidth="60" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Button>
        </DataTemplate>
    </Window.Resources>
    <Border Background="#EC1E1E1E" CornerRadius="22" BorderBrush="#26FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="50" ShadowDepth="14" Direction="270" Opacity="0.4" Color="Black"/>
        </Border.Effect>
        <Grid>
            <!-- 검색 모드 -->
            <StackPanel x:Name="SearchModePanel">
                <Grid Margin="26,22,26,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                               Foreground="#8CFFFFFF" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Grid Grid.Column="1">
                        <TextBlock x:Name="GhostTextBlock" Foreground="#4DFFFFFF" FontSize="29" FontWeight="Light" IsHitTestVisible="False"/>
                        <TextBox x:Name="QueryBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="#F5FFFFFF"
                                 CaretBrush="#5A9EFF"
                                 FontSize="29"
                                 FontWeight="Light"
                                 Padding="0"
                                 TextChanged="QueryBox_TextChanged"/>
                    </Grid>
                </Grid>
                <Border Height="1" Background="#12FFFFFF" Margin="26,0"/>

                <StackPanel x:Name="FavoritesSection" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="24,16,24,16">
                        <ItemsControl x:Name="FavoritesList" ItemTemplate="{StaticResource IconButtonTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <Button x:Name="AddFavoriteButton" Click="AddFavoriteButton_Click"
                                Template="{StaticResource FlatButtonTemplate}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand" Width="60">
                            <StackPanel HorizontalAlignment="Center">
                                <Border Width="44" Height="44" Background="#14FFFFFF" CornerRadius="12">
                                    <TextBlock Text="+" Foreground="#B3FFFFFF" FontSize="21"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="추가" Foreground="#AEFFFFFF" FontSize="11"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <StackPanel x:Name="TopAppsSection" Visibility="Collapsed">
                        <Border Height="1" Background="#12FFFFFF" Margin="24,0"/>
                        <StackPanel Margin="24,14,24,14">
                            <TextBlock Text="자주 쓰는 앱" Foreground="#66FFFFFF" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,12"/>
                            <ItemsControl x:Name="TopAppsList" ItemTemplate="{StaticResource PlainIconButtonTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                    <Border Height="1" Background="#12FFFFFF" Margin="26,0"/>
                </StackPanel>

                <ListBox x:Name="ResultsList"
                         Background="Transparent"
                         BorderThickness="0"
                         MaxHeight="420"
                         Margin="10,6,10,10"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Focusable="False"
                         PreviewMouseLeftButtonUp="ResultsList_PreviewMouseLeftButtonUp">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="12,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Image Grid.Column="0" Source="{Binding Icon}" Width="34" Height="34" Margin="0,0,14,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" Foreground="#F5FFFFFF" FontSize="15.5"/>
                                    <TextBlock Text="{Binding Subtitle}" Foreground="#8CFFFFFF" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Background="Transparent" CornerRadius="10" Margin="4,1">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#4D5A9EFF"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#10FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Border x:Name="AskAiSection" Visibility="Collapsed" BorderThickness="0">
                    <StackPanel>
                        <Border Height="1" Background="#12FFFFFF" Margin="26,0"/>
                        <Button x:Name="AskAiButton" Click="AskAiButton_Click"
                                Template="{StaticResource FlatButtonTemplate}"
                                Background="Transparent" BorderThickness="0" Cursor="Hand"
                                HorizontalContentAlignment="Left">
                            <StackPanel Orientation="Horizontal" Margin="26,14,26,14">
                                <Border Width="34" Height="34" Background="#14FFFFFF" CornerRadius="17" Margin="0,0,14,0">
                                    <TextBlock Text="&#10024;" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="AskAiLabel" Text="Ask AI" Foreground="#F5FFFFFF" FontSize="15" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- AI 채팅 모드 -->
            <Grid x:Name="ChatModePanel" Visibility="Collapsed" Height="520">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="22,16,22,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="30" Height="30" Background="#14FFFFFF" CornerRadius="15"
                            Cursor="Hand" MouseLeftButtonUp="BackFromChat_Click">
                        <TextBlock Text="&#8592;" Foreground="#F5FFFFFF" FontSize="15"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Column="1" Text="AI Chat" Foreground="#F5FFFFFF" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                </Grid>
                <Border Grid.Row="1" Height="1" Background="#12FFFFFF" Margin="22,0"/>

                <ScrollViewer Grid.Row="2" x:Name="ChatScroll" Margin="22,10,22,10">
                    <ItemsControl x:Name="ChatMessagesList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border HorizontalAlignment="{Binding Alignment}"
                                        Background="{Binding BubbleBrush}"
                                        CornerRadius="16"
                                        Margin="0,4"
                                        MaxWidth="420"
                                        Padding="14,9">
                                    <TextBlock Text="{Binding Text}" Foreground="#F5FFFFFF" TextWrapping="Wrap" FontSize="13.5"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="3" Height="1" Background="#12FFFFFF" Margin="22,0"/>

                <Grid Grid.Row="4" Margin="16,10,16,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ChatInputBox" Grid.Column="0"
                             Background="Transparent" BorderThickness="0" Foreground="#F5FFFFFF" CaretBrush="#5A9EFF"
                             FontSize="14" Padding="8" TextWrapping="Wrap"
                             PreviewKeyDown="ChatInputBox_PreviewKeyDown"/>
                    <Border Grid.Column="1" Width="36" Height="36" Background="#5A9EFF" CornerRadius="18"
                            Cursor="Hand" MouseLeftButtonUp="SendChat_Click">
                        <TextBlock Text="&#8593;" Foreground="White" FontSize="16" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
